# Supabase (obligatorias para producción)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (solo servidor — obligatoria para registrar y gestionar centros)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Moderación (solo servidor — panel /moderacion)
MODERADOR_ACCESS_TOKEN=change-me-in-production
# Alias aceptado por compatibilidad si ya lo configuraste con este nombre:
# MODERADOR_ACCES_TOKEN=change-me-in-production

# AI chatbot (solo servidor)
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
# Opcional: si defines AI_MODEL, forzará un solo modelo para todo.
# AI_MODEL=gemini-2.5-flash
# Recomendado en híbrido:
AI_MODEL_FLASH=gemini-2.5-flash
AI_MODEL_PRO=gemini-2.5-pro
