# País a mostrar (filtra la tabla centros_acopio por la columna pais)
FILTRO_PAIS=VE
DONAR_IFRAME_URL=https://tu-link-de-donacion.com

# Supabase (obligatorias para producción)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (solo servidor — obligatoria para registrar y gestionar centros)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Moderación (solo servidor — panel /moderacion)
MODERADOR_ACCESS_TOKEN=change-me-in-production
# Alias aceptado por compatibilidad si ya lo configuraste con este nombre:
# MODERADOR_ACCES_TOKEN=change-me-in-production
